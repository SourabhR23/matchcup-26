# ── BSD API ───────────────────────────────────────────────
BSD_TOKEN=your_bsd_api_token_here

# ── Supabase ──────────────────────────────────────────────
# Public URL (used by both frontend and backend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon key — frontend only (safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — backend/pipeline only (keep secret)
SUPABASE_SERVICE_ROLE=your_supabase_service_role_key
